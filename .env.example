# Clé API Gemini pour le serveur (secours si Firebase AI client indisponible).
# Obtenez-la sur https://aistudio.google.com/apikey
# L'ingestion utilise d'abord Firebase AI Logic (projet Blaze) côté navigateur.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
